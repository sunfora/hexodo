{
  "version": "0.2.0",
  "configurations": [
     {
        "name": "xdebug",
        "type": "php",
        "request": "launch",
        "port": 9003
      },
      {
        "name": "gdb",
        "type": "cppdbg",
        "request": "attach",
        "processId": "${command:pickProcess}",
        "MIMode": "gdb",
        "setupCommands": [
          {
            "description": "Enable pretty-printing for gdb",
            "text": "-enable-pretty-printing",
            "ignoreFailures": true
          }
        ]
      }
  ],
  "compounds": [
    {
      "name": "CxPHP",
      "configurations": [
        "xdebug",
        "gdb"
      ]
    }
  ]
}
